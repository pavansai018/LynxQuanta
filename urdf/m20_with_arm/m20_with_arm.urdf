        <origin xyz="0.37646 0.0 0.03738" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="camera_front_link"/>
    </joint>


    <link name="camera_rear_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.040 0.090 0.025"/>
            </geometry>
            <material name="dark_grey">
                <color rgba="0.2 0.2 0.2 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.040 0.090 0.025"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.072"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="camera_rear_joint" type="fixed">
        <!-- Official M20 coords: X=-376.46mm Y=0 Z=37.38mm (page 10 hardware manual) -->
        <origin xyz="-0.37646 0.0 0.03738" rpy="0 0 3.14159265"/>
        <parent link="base_link"/>
        <child link="camera_rear_link"/>
    </joint>

    <link name="lidar_front_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.040" radius="0.035"/>
            </geometry>
            <material name="dark_grey">
                <color rgba="0.2 0.2 0.2 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.040" radius="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.190"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="lidar_front_joint" type="fixed">
        <!-- Official M20 coords: X=320.28mm Y=0 Z=-13mm (page 10 hardware manual) -->
        <!-- <origin xyz="0.32028 0.0 -0.013" rpy="0 0 0"/> -->
        <origin xyz="0.43 0.0 0.11" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="lidar_front_link"/>
    </joint>

    <link name="lidar_rear_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.040" radius="0.035"/>
            </geometry>
            <material name="dark_grey">
                <color rgba="0.2 0.2 0.2 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.040" radius="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.190"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="lidar_rear_joint" type="fixed">
        <!-- Official M20 coords: X=-320.28mm Y=0 Z=-13mm (page 10 hardware manual) -->
        <!-- <origin xyz="-0.32028 0.0 -0.013" rpy="0 0 3.14159265"/> -->
        <origin xyz="-0.43 0.0 0.11" rpy="0 0 3.14159265"/>
        <parent link="base_link"/>
        <child link="lidar_rear_link"/>
    </joint>

    <!-- ================================================================== -->
    <!--  IMU LINK & JOINT                                                    -->
    <!--  Official M20 coords (page 10 hardware manual):                      -->
    <!--    X = 63.2mm,  Y = -26.8mm,  Z = -43.5mm                           -->
    <!--  relative to body coordinate system (base_link origin)               -->
    <!-- ================================================================== -->
    <link name="imu_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.020 0.020 0.010"/>
            </geometry>
            <material name="dark_grey">
                <color rgba="0.2 0.2 0.2 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.020 0.020 0.010"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.015"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
                               iyy="0.0001" iyz="0.0"
                                            izz="0.0001"/>
        </inertial>
    </link>
    <joint name="imu_joint" type="fixed">
        <!-- Official M20 coords: X=63.2mm Y=-26.8mm Z=-43.5mm -->
        <origin xyz="0.0632 -0.0268 -0.0435" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="imu_link"/>
    </joint>
    <ros2_control name="m20_with_arm_system" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
        <joint name="fr_hipx_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fr_hipy_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fr_knee_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fl_hipx_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fl_hipy_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fl_knee_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hr_hipx_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hr_hipy_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hr_knee_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hl_hipx_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hl_hipy_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hl_knee_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hl_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="hr_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fl_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="fr_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <!-- Arm Control -->
        <joint name="arm_joint1">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="arm_joint2">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="arm_joint3">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="arm_joint4">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="arm_joint5">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="arm_joint6">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="arm_joint7">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="arm_joint8">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>
    <gazebo reference="camera_front_link">
        <sensor name="camera_front" type="rgbd_camera">
            <always_on>1</always_on>
            <update_rate>30</update_rate>
            <topic>camera_front</topic>
            <gz_frame_id>camera_front_link</gz_frame_id>
            <camera name="camera_front">
                <!-- 60° horizontal FOV — typical for a RealSense-class sensor -->
                <horizontal_fov>1.0472</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>10.0</far>
                </clip>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.007</stddev>
                </noise>
                <depth_camera>
                    <clip>
                        <near>0.1</near>
                        <far>10.0</far>
                    </clip>
                </depth_camera>
                <lens>
                    <intrinsics>
                        <!-- fx, fy, cx, cy — reasonable defaults for 640×480 -->
                        <fx>554.254691</fx>
                        <fy>554.254691</fy>
                        <cx>320.5</cx>
                        <cy>240.5</cy>
                        <s>0.0</s>
                    </intrinsics>
                </lens>
            </camera>
        </sensor>
    </gazebo>

    <gazebo reference="camera_rear_link">
        <sensor name="camera_rear" type="rgbd_camera">
            <always_on>1</always_on>
            <update_rate>30</update_rate>
            <topic>camera_rear</topic>
            <gz_frame_id>camera_rear_link</gz_frame_id>
            <camera name="camera_rear">
                <horizontal_fov>1.0472</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>10.0</far>
                </clip>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.007</stddev>
                </noise>
                <depth_camera>
                    <clip>
                        <near>0.1</near>
                        <far>10.0</far>
                    </clip>
                </depth_camera>
                <lens>
                    <intrinsics>
                        <fx>554.254691</fx>
                        <fy>554.254691</fy>
                        <cx>320.5</cx>
                        <cy>240.5</cy>
                        <s>0.0</s>
                    </intrinsics>
                </lens>
            </camera>
        </sensor>
    </gazebo>

    <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
    <!--  FRONT 3D LiDAR — 96-line  |  Gazebo Harmonic (gz-sim 8)          -->
    <!--  Horizontal : 1800 rays × 0.2°  |  360° full scan                 -->
    <!--  Vertical   : 96 channels × 0.52°  |  ±25° FOV (-0.436 to +0.436 rad) -->
    <!--  Range      : 0.1 m – 50 m  |  Rate : 10 Hz                       -->
    <!--  Gz topics  →  ROS 2 (via ros_gz_bridge)                          -->
    <!--    /lidar_front         → sensor_msgs/msg/LaserScan  (unused)     -->
    <!--    /lidar_front/points  → sensor_msgs/msg/PointCloud2  (used)     -->
    <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
    <gazebo reference="lidar_front_link">
        <sensor name="lidar_front" type="gpu_lidar">
            <always_on>1</always_on>
            <update_rate>10</update_rate>
            <!-- Gazebo publishes two topics automatically:                 -->
            <!--   <topic>          → gz LaserScan  (2D projection)        -->
            <!--   <topic>/points   → gz PointCloud (full 3D cloud) ← used -->
            <topic>lidar_front</topic>
            <gz_frame_id>lidar_front_link</gz_frame_id>
            <lidar>
                <scan>
                    <horizontal>
                        <!-- 1800 rays → 0.2° angular resolution, 360° -->
                        <samples>1800</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159265</min_angle>
                        <max_angle>3.14159265</max_angle>
                    </horizontal>
                    <vertical>
                        <!-- 96 channels over ±25° vertical FOV -->
                        <samples>96</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.43633231</min_angle>  <!-- -25 deg -->
                        <max_angle>0.43633231</max_angle>   <!-- +25 deg -->
                    </vertical>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>50.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </lidar>
            <visualize>false</visualize>
        </sensor>
    </gazebo>

    <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
    <!--  REAR 3D LiDAR — 96-line  |  Gazebo Harmonic (gz-sim 8)           -->
    <!--  Identical spec to front LiDAR; joint yaw=π orients the frame.    -->
    <!--  Gz topics  →  ROS 2 (via ros_gz_bridge)                          -->
    <!--    /lidar_rear         → sensor_msgs/msg/LaserScan  (unused)      -->
    <!--    /lidar_rear/points  → sensor_msgs/msg/PointCloud2  (used)      -->
    <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
    <gazebo reference="lidar_rear_link">
        <sensor name="lidar_rear" type="gpu_lidar">
            <always_on>1</always_on>
            <update_rate>10</update_rate>
            <topic>lidar_rear</topic>
            <gz_frame_id>lidar_rear_link</gz_frame_id>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>1800</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159265</min_angle>
                        <max_angle>3.14159265</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>96</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.43633231</min_angle>  <!-- -25 deg -->
                        <max_angle>0.43633231</max_angle>   <!-- +25 deg -->
                    </vertical>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>50.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </lidar>
            <visualize>false</visualize>
        </sensor>
    </gazebo>

    <!-- ================================================================== -->
    <!--  SENSOR SYSTEM PLUGINS  — Gazebo Harmonic / ignition convention   -->
    <!--                                                                    -->
    <!--  THIS BLOCK IS MANDATORY.  Without it every sensor in the URDF    -->
    <!--  is parsed but never activated — cameras publish no frames and     -->
    <!--  LiDARs report 0.000 range.                                        -->
    <!--                                                                    -->
    <!--  render_engine ogre2 is required for rgbd_camera (depth output).  -->
    <!-- ================================================================== -->
    <!-- ================================================================== -->
    <!--  IMU SENSOR — Gazebo Harmonic                                        -->
    <!--  Publishes gz topic: /imu/data  (bridged to ROS 2 via bridge)        -->
    <!--  Rate: 200 Hz                                                         -->
    <!-- ================================================================== -->
    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>1</always_on>
            <update_rate>200</update_rate>
            <topic>imu/data</topic>
            <gz_frame_id>imu_link</gz_frame_id>
            <imu>
                <angular_velocity>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <!-- Sensors system plugin -->

    <!-- If sensors still don't work, swap to ignition-gazebo-sensors-system -->
    <gazebo>
        <plugin filename="gz-sim-sensors-system"
                name="gz::sim::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-imu-system"
                name="gz::sim::systems::Imu"/>
    </gazebo>

    <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
    <!--  ODOMETRY PUBLISHER PLUGIN                                         -->
    <!--                                                                    -->
    <!--  Publishes two things that slam_toolbox and Nav2 REQUIRE:          -->
    <!--    1. /odom  (nav_msgs/Odometry) — bridged via ros_gz_bridge       -->
    <!--    2. odom → base_footprint TF  — bridged via /tf bridge           -->
    <!--                                                                    -->
    <!--  Without this plugin, gz_ros2_control alone does NOT produce any   -->
    <!--  odometry, so EKF has nothing to consume and the map frame never   -->
    <!--  appears.                                                           -->
    <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
    <gazebo>
        <plugin filename="gz-sim-odometry-publisher-system"
                name="gz::sim::systems::OdometryPublisher">
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base_footprint</robot_base_frame>
            <odom_publish_frequency>30</odom_publish_frequency>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin filename="ignition-gazebo-joint-state-publisher-system" name="ignition::gazebo::systems::JointStatePublisher">
            <topic>/joint_states</topic>
        </plugin>
    </gazebo>
    <gazebo>
    <plugin
        filename="gz_ros2_control-system"
        name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(find lynx_quanta)/config/m20_with_arm_controller.yaml</parameters>
    </plugin>
    </gazebo>

</robot>
