<?xml version="1.0" encoding="utf-8"?>
<!--
  M20 Lynx Quadruped + RM65-6FB-V 6-DOF Arm  — Integrated URDF
  =============================================================
  Arm mounting:
    • Rail area  : 270 mm × 165 mm centred on back of base_link
    • Mount origin in base_link frame: X=0.00 m, Y=0.00 m, Z=0.075 m
      (Z = top surface of body box ~70 mm + 5 mm plate clearance)
    • Height budget: arm_joint_1 lifts the first link 240.5 mm above
      arm_base_link, staying well under the 300 mm recommended limit
      in the default (stowed) pose.

  Naming convention:
    • All arm links/joints are prefixed "arm_" to avoid clashes with
      the dog's own base_link and sensor links.
    • arm_mount_link  – 10 mm aluminium plate representing the rail
      adapter bracket; 270 × 165 × 10 mm, mass ≈ 0.120 kg.
    • arm_base_link   – RM65 base (was "base_link" in the arm URDF).
    • arm_link_1 … arm_link_6  – RM65 links 1-6.
    • arm_camera_rolink / arm_camera_link – wrist camera assembly.

  Mesh paths:
    • Dog  : file://$(find lynx_quanta)/meshes/m20/<name>.dae
    • Arm  : file://$(find lynx_quanta)/meshes/arm_v2/<name>.STL
      ► Copy RM65-6FB-V/meshes/*.STL  into  <pkg>/meshes/arm_v2/
        (you already said you created meshes/arm_v2/ — just drop the
        STL files there; no rename needed).

  ros2_control:
    • Arm joints arm_joint_1 … arm_joint_6 added as position-controlled.
    • arm_camera_rojoint is passive (effort/velocity limits = 0) and is
      NOT added to ros2_control.
    • Controller YAML (m20_with_arm_controller.yaml) needs an
      arm_controller section — see comment at the bottom of the file.
-->
<robot name="m20_with_arm" xmlns:xacro="http://ros.org/wiki/xacro">
<xacro:arg name="ros2_control_yaml" default=""/>

    <!-- ================================================================== -->
    <!--  DOG BASE                                                           -->
    <!-- ================================================================== -->

    <link name="base_footprint"/>
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <inertial>
            <origin xyz="0.00355105878308153 0.0016507579200937 -0.00346462146571654" rpy="0 0 0"/>
            <mass value="15.882"/>
            <inertia ixx="0.087919" ixy="0.001396" ixz="0.000111" iyy="0.533522" iyz="0.000519" izz="0.563492"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/m20/base_link.dae"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.75 0.09 0.14"/></geometry>
        </collision>
        <collision>
            <origin xyz="0 0.045 0" rpy="0 1.57079632 0"/>
            <geometry><cylinder length="0.75" radius="0.07"/></geometry>
        </collision>
        <collision>
            <origin xyz="0 -0.045 0" rpy="0 1.57079632 0"/>
            <geometry><cylinder length="0.75" radius="0.07"/></geometry>
        </collision>
    </link>

    <!-- ================================================================== -->
    <!--  FRONT-LEFT LEG                                                     -->
    <!-- ================================================================== -->

    <link name="fl_hipx">
        <inertial>
            <origin xyz="-0.0111893129496933 0.00891693461032669 0.000405665689861192" rpy="0 0 0"/>
