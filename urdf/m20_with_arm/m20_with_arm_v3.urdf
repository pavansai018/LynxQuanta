    </link>
    <joint name="camera_front_joint" type="fixed">
        <!-- Official M20 coords: X=376.46mm Y=0 Z=37.38mm (page 10 hardware manual) -->
        <origin xyz="0.37646 0.0 0.03738" rpy="0 0 0"/>
        <parent link="base_link"/><child link="camera_front_link"/>
    </joint>

    <link name="camera_rear_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.040 0.090 0.025"/></geometry>
            <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.040 0.090 0.025"/></geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.072"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="camera_rear_joint" type="fixed">
        <!-- Official M20 coords: X=-376.46mm Y=0 Z=37.38mm (page 10 hardware manual) -->
        <origin xyz="-0.37646 0.0 0.03738" rpy="0 0 3.14159265"/>
        <parent link="base_link"/><child link="camera_rear_link"/>
    </joint>

    <link name="lidar_front_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><cylinder length="0.040" radius="0.035"/></geometry>
            <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><cylinder length="0.040" radius="0.035"/></geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.190"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="lidar_front_joint" type="fixed">
        <!-- Official M20 coords: X=320.28mm Y=0 Z=-13mm (page 10 hardware manual) -->
        <origin xyz="0.32028 0.0 -0.013" rpy="0 0 0"/>
        <parent link="base_link"/><child link="lidar_front_link"/>
    </joint>

    <link name="lidar_rear_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><cylinder length="0.040" radius="0.035"/></geometry>
            <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><cylinder length="0.040" radius="0.035"/></geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.190"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="lidar_rear_joint" type="fixed">
        <!-- Official M20 coords: X=-320.28mm Y=0 Z=-13mm (page 10 hardware manual) -->
        <origin xyz="-0.32028 0.0 -0.013" rpy="0 0 3.14159265"/>
        <parent link="base_link"/><child link="lidar_rear_link"/>
    </joint>

    <link name="imu_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.020 0.020 0.010"/></geometry>
            <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.020 0.020 0.010"/></geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.015"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="imu_joint" type="fixed">
        <!-- Official M20 coords: X=63.2mm Y=-26.8mm Z=-43.5mm -->
        <origin xyz="0.0632 -0.0268 -0.0435" rpy="0 0 0"/>
        <parent link="base_link"/><child link="imu_link"/>
    </joint>

    <!-- ================================================================== -->
    <!--  ARM MOUNTING BRACKET                                               -->
    <!--  270 mm × 165 mm × 10 mm aluminium adapter plate.                  -->
    <!--  Centred on the back rail; origin placed at the top surface of      -->
    <!--  base_link (Z ≈ 0.075 m = body half-height 0.07 m + 5 mm gap).    -->
    <!--  The arm base sits on top of this plate (+10 mm in Z).             -->
    <!-- ================================================================== -->
    <link name="arm_mount_link">
        <visual>
            <origin xyz="0 0 0.005" rpy="0 0 0"/>
            <geometry><box size="0.270 0.165 0.010"/></geometry>
            <material name="arm_mount_grey"><color rgba="0.4 0.4 0.4 1.0"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0.005" rpy="0 0 0"/>
            <geometry><box size="0.270 0.165 0.010"/></geometry>
        </collision>
        <inertial>
            <!-- 6061-Al plate, ~0.120 kg; inertia for 270×165×10 mm box -->
            <origin xyz="0 0 0.005" rpy="0 0 0"/>
            <mass value="0.120"/>
            <inertia
                ixx="3.88e-04" ixy="0.0" ixz="0.0"
                iyy="9.13e-04" iyz="0.0"
                izz="1.29e-03"/>
        </inertial>
    </link>

    <!-- Fixed joint: dog body → mounting plate -->
    <!-- ► Tune X/Y here if you want the arm off-centre on the rail.       -->
    <!-- ► Z=0.075 keeps the plate just above the body top surface.        -->
    <joint name="arm_mount_joint" type="fixed">
        <origin xyz="0.0 0.0 0.075" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="arm_mount_link"/>
    </joint>

    <!-- ================================================================== -->
    <!--  RM65-6FB-V ARM  (all names prefixed "arm_")                       -->
    <!--  Mesh path : file://$(find lynx_quanta)/meshes/arm_v2/<name>.STL      -->
    <!--                                                                    -->
    <!--  Chain:  arm_base_link                                             -->
    <!--            └─ arm_joint_1 (yaw,   Z, ±178°)                       -->
    <!--               └─ arm_link_1                                        -->
    <!--                  └─ arm_joint_2 (pitch, Z, ±130°)                 -->
    <!--                     └─ arm_link_2                                  -->
    <!--                        └─ arm_joint_3 (pitch, Z, ±135°)           -->
    <!--                           └─ arm_link_3                            -->
    <!--                              └─ arm_joint_4 (roll,  Z, ±178°)     -->
    <!--                                 └─ arm_link_4                      -->
    <!--                                    └─ arm_joint_5 (pitch, Z, ±128°)-->
    <!--                                       └─ arm_link_5                -->
    <!--                                          └─ arm_joint_6 (roll,  Z, ±360°) -->
    <!--                                             └─ arm_link_6          -->
    <!--                                                └─ arm_camera_rojoint (passive) -->
    <!--                                                   └─ arm_camera_rolink -->
    <!--                                                      └─ arm_camera_joint (fixed) -->
    <!--                                                         └─ arm_camera_link -->
    <!-- ================================================================== -->

    <link name="arm_base_link">
        <inertial>
            <origin xyz="-0.00049987 -5.2709E-05 0.060019" rpy="0 0 0"/>
            <mass value="1.862"/>
            <inertia
                ixx="0.0017232" ixy="-3.1058E-06" ixz="3.7924E-05"
                iyy="0.0017051" iyz="-1.3691E-06"
                izz="0.00090158"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/base_link.STL"/>
            </geometry>
            <material name="arm_white"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2_v2/base_link.STL"/>
            </geometry>
        </collision>
    </link>

    <!-- Fixed joint: mounting plate → arm base -->
    <!-- arm_base_link Z=0 sits on top of the 10 mm plate                  -->
    <joint name="arm_base_joint" type="fixed">
        <origin xyz="0.0 0.0 0.010" rpy="0 0 0"/>
        <parent link="arm_mount_link"/>
        <child link="arm_base_link"/>
    </joint>

    <!-- ── Link 1 ── -->
    <link name="arm_link_1">
        <inertial>
            <origin xyz="0.000941 0.007803 -0.10744" rpy="0 0 0"/>
            <mass value="1.51"/>
            <inertia
                ixx="0.002662223" ixy="-0.000026849" ixz="-0.000013775"
                iyy="0.002331685" iyz="-0.000078667"
                izz="0.001663712"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_1.STL"/>
            </geometry>
            <material name="arm_white"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_1.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="arm_joint_1" type="revolute">
        <!-- Shoulder yaw — 240.5 mm above arm_base_link -->
        <origin xyz="0 0 0.2405" rpy="0 0 0"/>
        <parent link="arm_base_link"/><child link="arm_link_1"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.106" upper="3.106" effort="60" velocity="3.14"/>
        <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <!-- ── Link 2 ── -->
    <link name="arm_link_2">
        <inertial>
            <origin xyz="0.183722 0.000103 -0.001665" rpy="0 0 0"/>
            <mass value="1.653"/>
            <inertia
                ixx="0.001706953" ixy="-0.000006995" ixz="0.001809254"
                iyy="0.014713776" iyz="0.000006223"
                izz="0.014239805"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_2.STL"/>
            </geometry>
            <material name="arm_white"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_2.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="arm_joint_2" type="revolute">
        <origin xyz="0 0 0" rpy="1.5708 -1.5708 0"/>
        <parent link="arm_link_1"/><child link="arm_link_2"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.2689" upper="2.2689" effort="60" velocity="3.14"/>
        <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <!-- ── Link 3 ── -->
    <link name="arm_link_3">
        <inertial>
            <origin xyz="0.000029 -0.090105 0.004039" rpy="0 0 0"/>
            <mass value="0.726"/>
            <inertia
                ixx="0.001350874" ixy="0.000001069" ixz="-0.000000228"
                iyy="0.000360021" iyz="-0.000219904"
                izz="0.001331598"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_3.STL"/>
            </geometry>
            <material name="arm_white"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_3.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="arm_joint_3" type="revolute">
        <origin xyz="0.256 0 0" rpy="0 0 1.5708"/>
        <parent link="arm_link_2"/><child link="arm_link_3"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.356" upper="2.356" effort="30" velocity="3.14"/>
        <dynamics damping="0.05" friction="0.0"/>
    </joint>

    <!-- ── Link 4 ── -->
    <link name="arm_link_4">
        <inertial>
            <origin xyz="0.000007 -0.009486 -0.008041" rpy="0 0 0"/>
            <mass value="0.671"/>
            <inertia
                ixx="0.000690221" ixy="-0.000000865" ixz="-0.000000692"
                iyy="0.000552834" iyz="0.000016411"
                izz="0.000425835"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_4.STL"/>
            </geometry>
            <material name="arm_white"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_4.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="arm_joint_4" type="revolute">
        <origin xyz="0 -0.21 0" rpy="1.5708 0 0"/>
        <parent link="arm_link_3"/><child link="arm_link_4"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.106" upper="3.106" effort="10" velocity="3.14"/>
        <dynamics damping="0.05" friction="0.0"/>
    </joint>

    <!-- ── Link 5 ── -->
    <link name="arm_link_5">
        <inertial>
            <origin xyz="0.000032 -0.083769 0.002326" rpy="0 0 0"/>
            <mass value="0.647"/>
            <inertia
                ixx="0.000834052" ixy="0.000000952" ixz="-0.000000257"
                iyy="0.000281767" iyz="-0.000111750"
                izz="0.000821714"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_5.STL"/>
            </geometry>
            <material name="arm_white"><color rgba="1 1 1 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_5.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="arm_joint_5" type="revolute">
        <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
        <parent link="arm_link_4"/><child link="arm_link_5"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.234" upper="2.234" effort="10" velocity="3.14"/>
        <dynamics damping="0.05" friction="0.0"/>
    </joint>

    <!-- ── Link 6  (wrist flange) ── -->
    <link name="arm_link_6">
        <inertial>
            <origin xyz="-0.000569 0.00029 -0.010569" rpy="0 0 0"/>
            <mass value="0.14434"/>
            <inertia
                ixx="3.043E-05" ixy="2.622E-09" ixz="2.199E-08"
                iyy="3.604E-05" iyz="1.195E-08"
                izz="5.52E-05"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_6.STL"/>
            </geometry>
            <material name="arm_silver"><color rgba="0.753 0.753 0.753 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/link_6.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="arm_joint_6" type="revolute">
        <origin xyz="0 -0.18448 0" rpy="1.5708 0 0"/>
        <parent link="arm_link_5"/><child link="arm_link_6"/>
        <axis xyz="0 0 1"/>
        <limit lower="-6.28" upper="6.28" effort="10" velocity="3.14"/>
        <dynamics damping="0.05" friction="0.0"/>
    </joint>

    <!-- ── Wrist camera rotation link (passive) ── -->
    <link name="arm_camera_rolink">
        <inertial>
            <origin xyz="0.0080749 -0.044495 0.0085055" rpy="0 0 0"/>
            <mass value="0.019695"/>
            <inertia
                ixx="1.5115E-05" ixy="-1.9139E-06" ixz="-8.811E-09"
                iyy="2.7638E-06" iyz="6.7136E-09"
                izz="1.399E-05"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/camera_rolink.STL"/>
            </geometry>
            <material name="arm_silver"><color rgba="0.753 0.753 0.753 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/camera_rolink.STL"/>
            </geometry>
        </collision>
    </link>
    <!-- Passive tilt joint — effort=0, velocity=0; NOT in ros2_control -->
    <joint name="arm_camera_rojoint" type="revolute">
        <origin xyz="-0.033 -0.0085 -0.05388" rpy="1.5708 -1.5708 3.14"/>
        <parent link="arm_link_6"/><child link="arm_camera_rolink"/>
        <axis xyz="0 0 1"/>
        <limit lower="0" upper="1.05" effort="0" velocity="0"/>
    </joint>

    <!-- ── Wrist camera (fixed to camera_rolink) ── -->
    <link name="arm_camera_link">
        <inertial>
            <origin xyz="-0.009 -1.1052E-09 -0.011436" rpy="0 0 0"/>
            <mass value="0.03915"/>
            <inertia
                ixx="7.2029E-06" ixy="1.2847E-13" ixz="4.6827E-14"
                iyy="7.199E-06"  iyz="4.4495E-13"
                izz="1.1014E-05"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/camera_link.STL"/>
            </geometry>
            <material name="arm_blue"><color rgba="0.792 0.820 0.933 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find lynx_quanta)/meshes/arm_v2/camera_link.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="arm_camera_joint" type="fixed">
        <origin xyz="0.029031 -0.10022 -0.0005" rpy="0 1.5708 0"/>
        <parent link="arm_camera_rolink"/><child link="arm_camera_link"/>
        <axis xyz="0 0 0"/>
    </joint>

    <!-- ================================================================== -->
    <!--  ros2_control — combined dog + arm                                  -->
    <!-- ================================================================== -->
    <ros2_control name="m20_with_arm_system" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <!-- ── Dog legs ── -->
        <joint name="fr_hipx_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fr_hipy_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fr_knee_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fl_hipx_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fl_hipy_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fl_knee_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hr_hipx_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hr_hipy_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hr_knee_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hl_hipx_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hl_hipy_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hl_knee_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <!-- ── Dog wheels ── -->
        <joint name="hl_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hr_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fl_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="fr_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <!-- ── RM65 arm (6 DOF, position control) ── -->
        <joint name="arm_joint_1">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="arm_joint_2">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="arm_joint_3">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="arm_joint_4">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="arm_joint_5">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="arm_joint_6">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <!-- arm_camera_rojoint is passive (effort/vel = 0) — omitted -->
    </ros2_control>

    <!-- ================================================================== -->
    <!--  GAZEBO PLUGINS & SENSOR DEFINITIONS                                -->
    <!-- ================================================================== -->

    <!-- Dog cameras -->
    <gazebo reference="camera_front_link">
        <sensor name="camera_front" type="rgbd_camera">
            <always_on>1</always_on>
            <update_rate>30</update_rate>
            <topic>camera_front</topic>
            <gz_frame_id>camera_front_link</gz_frame_id>
            <camera name="camera_front">
                <horizontal_fov>1.0472</horizontal_fov>
                <image><width>640</width><height>480</height><format>R8G8B8</format></image>
                <clip><near>0.1</near><far>10.0</far></clip>
                <noise><type>gaussian</type><mean>0.0</mean><stddev>0.007</stddev></noise>
                <depth_camera><clip><near>0.1</near><far>10.0</far></clip></depth_camera>
                <lens><intrinsics><fx>554.254691</fx><fy>554.254691</fy><cx>320.5</cx><cy>240.5</cy><s>0.0</s></intrinsics></lens>
            </camera>
        </sensor>
    </gazebo>

    <gazebo reference="camera_rear_link">
        <sensor name="camera_rear" type="rgbd_camera">
            <always_on>1</always_on>
            <update_rate>30</update_rate>
            <topic>camera_rear</topic>
            <gz_frame_id>camera_rear_link</gz_frame_id>
            <camera name="camera_rear">
                <horizontal_fov>1.0472</horizontal_fov>
                <image><width>640</width><height>480</height><format>R8G8B8</format></image>
                <clip><near>0.1</near><far>10.0</far></clip>
                <noise><type>gaussian</type><mean>0.0</mean><stddev>0.007</stddev></noise>
                <depth_camera><clip><near>0.1</near><far>10.0</far></clip></depth_camera>
                <lens><intrinsics><fx>554.254691</fx><fy>554.254691</fy><cx>320.5</cx><cy>240.5</cy><s>0.0</s></intrinsics></lens>
            </camera>
        </sensor>
    </gazebo>

    <!-- Dog LiDARs -->
    <gazebo reference="lidar_front_link">
        <sensor name="lidar_front" type="gpu_lidar">
            <always_on>1</always_on>
            <update_rate>10</update_rate>
            <topic>lidar_front</topic>
            <gz_frame_id>lidar_front_link</gz_frame_id>
            <lidar>
                <scan>
                    <horizontal><samples>1800</samples><resolution>1</resolution><min_angle>-3.14159265</min_angle><max_angle>3.14159265</max_angle></horizontal>
                    <vertical><samples>96</samples><resolution>1</resolution><min_angle>-0.43633231</min_angle><max_angle>0.43633231</max_angle></vertical>
                </scan>
                <range><min>0.1</min><max>50.0</max><resolution>0.01</resolution></range>
                <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
            </lidar>
            <visualize>false</visualize>
        </sensor>
    </gazebo>

    <gazebo reference="lidar_rear_link">
        <sensor name="lidar_rear" type="gpu_lidar">
            <always_on>1</always_on>
            <update_rate>10</update_rate>
            <topic>lidar_rear</topic>
            <gz_frame_id>lidar_rear_link</gz_frame_id>
            <lidar>
                <scan>
                    <horizontal><samples>1800</samples><resolution>1</resolution><min_angle>-3.14159265</min_angle><max_angle>3.14159265</max_angle></horizontal>
                    <vertical><samples>96</samples><resolution>1</resolution><min_angle>-0.43633231</min_angle><max_angle>0.43633231</max_angle></vertical>
                </scan>
                <range><min>0.1</min><max>50.0</max><resolution>0.01</resolution></range>
                <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
            </lidar>
            <visualize>false</visualize>
        </sensor>
    </gazebo>

    <!-- Dog IMU -->
    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>1</always_on>
            <update_rate>200</update_rate>
            <topic>imu/data</topic>
            <gz_frame_id>imu_link</gz_frame_id>
            <imu>
                <angular_velocity>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <!-- ── Arm wrist camera (RGBD, 30 Hz) ── -->
    <!-- Published Gz topic: arm_camera  →  bridge to ROS 2 as needed      -->
    <gazebo reference="arm_camera_link">
        <sensor name="arm_wrist_camera" type="rgbd_camera">
            <always_on>1</always_on>
            <update_rate>30</update_rate>
            <topic>arm_camera</topic>
            <gz_frame_id>arm_camera_link</gz_frame_id>
            <camera name="arm_wrist_camera">
                <!-- 69° H-FOV ≈ typical RealSense D405 -->
                <horizontal_fov>1.2043</horizontal_fov>
                <image><width>640</width><height>480</height><format>R8G8B8</format></image>
                <clip><near>0.05</near><far>3.0</far></clip>
                <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
                <depth_camera><clip><near>0.05</near><far>3.0</far></clip></depth_camera>
                <lens>
                    <intrinsics>
                        <fx>554.254691</fx><fy>554.254691</fy>
                        <cx>320.5</cx><cy>240.5</cy><s>0.0</s>
                    </intrinsics>
                </lens>
            </camera>
        </sensor>
    </gazebo>

    <!-- System plugins -->
    <gazebo>
        <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-odometry-publisher-system"
                name="gz::sim::systems::OdometryPublisher">
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base_footprint</robot_base_frame>
            <odom_publish_frequency>30</odom_publish_frequency>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin filename="ignition-gazebo-joint-state-publisher-system"
                name="ignition::gazebo::systems::JointStatePublisher">
            <topic>/joint_states</topic>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin filename="gz_ros2_control-system"
                name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find lynx_quanta)/config/m20_with_arm_controller.yaml</parameters>
        </plugin>
    </gazebo>

    <!--
    ====================================================================
    REQUIRED: add this block to m20_with_arm_controller.yaml
    ====================================================================

    arm_controller:
      ros__parameters:
        type: joint_trajectory_controller/JointTrajectoryController
        joints:
          - arm_joint_1
          - arm_joint_2
          - arm_joint_3
          - arm_joint_4
          - arm_joint_5
          - arm_joint_6
        command_interfaces:
          - position
        state_interfaces:
          - position
          - velocity
        state_publish_rate: 50.0
        action_monitor_rate: 20.0
        allow_partial_joints_goal: false
        constraints:
          stopped_velocity_tolerance: 0.01
          goal_time: 0.6

    Also add  arm_controller  to the controller_manager's list of
    controllers to activate on startup.
    ====================================================================
    -->

</robot>
