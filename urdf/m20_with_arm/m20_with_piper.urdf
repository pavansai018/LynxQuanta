  <joint name="camera_front_joint" type="fixed">
    <!-- Official M20 coords: X=376.46mm Y=0 Z=37.38mm (hardware manual p.10) -->
    <origin xyz="0.37646 0.0 0.03738" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="camera_front_link"/>
  </joint>

  <link name="camera_rear_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.040 0.090 0.025"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.040 0.090 0.025"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.072"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="camera_rear_joint" type="fixed">
    <!-- Official M20 coords: X=-376.46mm Y=0 Z=37.38mm (hardware manual p.10) -->
    <origin xyz="-0.37646 0.0 0.03738" rpy="0 0 3.14159265"/>
    <parent link="base_link"/>
    <child  link="camera_rear_link"/>
  </joint>

  <link name="lidar_front_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.040" radius="0.035"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.040" radius="0.035"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.190"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="lidar_front_joint" type="fixed">
    <origin xyz="0.43 0.0 0.11" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="lidar_front_link"/>
  </joint>

  <link name="lidar_rear_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.040" radius="0.035"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.040" radius="0.035"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.190"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="lidar_rear_joint" type="fixed">
    <origin xyz="-0.43 0.0 0.11" rpy="0 0 3.14159265"/>
    <parent link="base_link"/>
    <child  link="lidar_rear_link"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.020 0.020 0.010"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.020 0.020 0.010"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.015"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <!-- Official M20 coords: X=63.2mm Y=-26.8mm Z=-43.5mm (hardware manual p.10) -->
    <origin xyz="0.0632 -0.0268 -0.0435" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="imu_link"/>
  </joint>

  <!-- ======================================================================
       PIPER ARM — MOUNTING INTERFACE
       ======================================================================
       Physical mount:
         • Centred on the 270 mm × 165 mm rail (x-span ±135 mm, y-span ±82.5 mm)
         • z = 0.09 m above base_link origin
             = top of M20 body (~0.07 m) + 20 mm aluminium mounting bracket
         • rpy = 0 0 0  →  arm Z-axis aligned with dog Z-axis (pointing up)
         • Height budget check at zero-pose:
             arm_base_link top     : 0.09 m
             arm_link1  (joint1 z) : 0.09 + 0.123  = 0.213 m
             Folded arm max ≈ 0.21 m above mount  << 0.30 m limit  ✓
       ====================================================================== -->
  <joint name="arm_mount_joint" type="fixed">
    <!-- Parent is the dog body; child is the Piper arm base -->
    <parent link="base_link"/>
    <child  link="arm_base_link"/>
    <!--
      x =  0.00 : centred fore-aft on the rail
      y =  0.00 : centred laterally
      z =  0.09 : top surface of body + bracket
      If you need the arm shifted forward for better reach, try x = 0.05.
      To rotate the arm 180° (facing rearward), set rpy = "0 0 3.14159265".
    -->
    <origin xyz="0.0 0.0 0.09" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
       PIPER ARM — LINKS & JOINTS
       All names prefixed with "arm_" to avoid any conflict with the dog.
       Mesh paths resolved via lynx_quanta package; STL files must be placed
       in:  <package_root>/meshes/piper/
       ====================================================================== -->

  <!-- ── arm_base_link ────────────────────────────────────────────────── -->
  <link name="arm_base_link">
    <inertial>
      <origin xyz="-0.00473641164191482 2.56829134630247E-05 0.041451518036016" rpy="0 0 0"/>
      <mass value="1.02"/>
      <inertia ixx="0.00267433" ixy="-0.00000073" ixz="-0.00017389"
               iyy="0.00282612" iyz="0.0000004"  izz="0.00089624"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/base_link.STL"/>
      </geometry>
      <material name="piper_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- ── arm_link1 — shoulder rotation (Z) ────────────────────────────── -->
  <link name="arm_link1">
    <inertial>
      <origin xyz="0.00032 -0.00041 -0.00348" rpy="0 0 0"/>
      <mass value="0.71"/>
      <inertia ixx="0.00050027" ixy="0.00000078" ixz="0.00000626"
               iyy="0.00040879" iyz="0.00000462" izz="0.00045802"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link1.STL"/>
      </geometry>
      <material name="piper_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link1.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="arm_joint1" type="revolute">
    <!-- Shoulder pan — 123 mm above arm base, rotates about arm Z -->
    <origin xyz="0 0 0.123" rpy="0 0 0"/>
    <parent link="arm_base_link"/>
    <child  link="arm_link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.618" upper="2.618" effort="100" velocity="5"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── arm_link2 — shoulder pitch ───────────────────────────────────── -->
  <link name="arm_link2">
    <inertial>
      <origin xyz="0.21852 -0.00861 0.00126" rpy="0 0 0"/>
      <mass value="1.16"/>
      <inertia ixx="0.00111915" ixy="0.00182916" ixz="0.00019233"
               iyy="0.06763251" iyz="0.00000767" izz="0.067559"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link2.STL"/>
      </geometry>
      <material name="piper_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link2.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="arm_joint2" type="revolute">
    <origin xyz="0 0 0" rpy="1.5708 -0.1359 -3.1416"/>
    <parent link="arm_link1"/>
    <child  link="arm_link2"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="3.14" effort="100" velocity="5"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── arm_link3 — elbow ────────────────────────────────────────────── -->
  <link name="arm_link3">
    <inertial>
      <origin xyz="-0.01999 -0.14808 -0.00053" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01347608" ixy="0.00161034" ixz="0.00000066"
               iyy="0.00046377" iyz="0.00000162" izz="0.01363321"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link3.STL"/>
      </geometry>
      <material name="piper_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link3.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="arm_joint3" type="revolute">
    <origin xyz="0.28503 0 0" rpy="0 0 -1.7939"/>
    <parent link="arm_link2"/>
    <child  link="arm_link3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.967" upper="0" effort="100" velocity="5"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ── arm_link4 — forearm roll ─────────────────────────────────────── -->
  <link name="arm_link4">
    <inertial>
      <origin xyz="0.00013 -0.00076 -0.00394" rpy="0 0 0"/>
      <mass value="0.38"/>
      <inertia ixx="0.00017844" ixy="0.00000062" ixz="0.00000067"
               iyy="0.00018914" iyz="0.00000408" izz="0.00014613"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link4.STL"/>
      </geometry>
      <material name="piper_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link4.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="arm_joint4" type="revolute">
    <origin xyz="-0.021984 -0.25075 0" rpy="1.5708 0 0"/>
    <parent link="arm_link3"/>
    <child  link="arm_link4"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.745" upper="1.745" effort="100" velocity="5"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- ── arm_link5 — wrist pitch ──────────────────────────────────────── -->
  <link name="arm_link5">
    <inertial>
      <origin xyz="0.00018 -0.06104 -0.00227" rpy="0 0 0"/>
      <mass value="0.383"/>
      <inertia ixx="0.00172318" ixy="0.00000259" ixz="0.00000010"
               iyy="0.00017936" iyz="0.00000990" izz="0.00171172"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link5.STL"/>
      </geometry>
      <material name="piper_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link5.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="arm_joint5" type="revolute">
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <parent link="arm_link4"/>
    <child  link="arm_link5"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.22" upper="1.22" effort="100" velocity="5"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- ── arm_link6 — wrist roll ───────────────────────────────────────── -->
  <link name="arm_link6">
    <inertial>
      <origin xyz="-0.00003 0.00006 0.04618" rpy="0 0 0"/>
      <mass value="0.007"/>
      <inertia ixx="0.00152112" ixy="0.00000202" ixz="0.00000261"
               iyy="0.00138626" iyz="0.00000002" izz="0.00031152"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link6.STL"/>
      </geometry>
      <material name="piper_light">
        <color rgba="0.898 0.918 0.929 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link6.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="arm_joint6" type="revolute">
    <origin xyz="8.8259E-05 -0.091 0" rpy="1.5708 0 0"/>
    <parent link="arm_link5"/>
    <child  link="arm_link6"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0944" upper="2.0944" effort="100" velocity="3"/>
    <dynamics damping="0.2" friction="0.02"/>
  </joint>

  <!-- ── arm_gripper_base — fixed flange on wrist ─────────────────────── -->
  <link name="arm_gripper_base">
    <inertial>
      <origin xyz="-0.000183807162235591 8.05033155577911E-05 0.0321436689908876" rpy="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00092934" ixy="0.00000034" ixz="-0.00000738"
               iyy="0.00071447" iyz="0.00000005" izz="0.00039442"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/gripper_base.STL"/>
      </geometry>
      <material name="gripper_black">
        <color rgba="0.08 0.08 0.08 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/gripper_base.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="arm_joint6_to_gripper_base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="arm_link6"/>
    <child  link="arm_gripper_base"/>
  </joint>

  <!-- ── arm_link7 — left gripper finger (prismatic) ──────────────────── -->
  <link name="arm_link7">
    <inertial>
      <origin xyz="0.00065123185041968 -0.0491929869131989 0.00972258769184025" rpy="0 0 0"/>
      <mass value="0.025"/>
      <inertia ixx="0.00007371" ixy="-0.00000113" ixz="0.00000021"
               iyy="0.00000781" iyz="-0.00001372" izz="0.0000747"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link7.STL"/>
      </geometry>
      <material name="gripper_black">
        <color rgba="0.08 0.08 0.08 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link7.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="arm_joint7" type="prismatic">
    <!-- Left finger: slides +Z in link7 local frame (opens away) -->
    <origin xyz="0 0 0.1358" rpy="1.5708 0 0"/>
    <parent link="arm_gripper_base"/>
    <child  link="arm_link7"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.035" effort="10" velocity="1"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <!-- ── arm_link8 — right gripper finger (prismatic, mirrored) ────────── -->
  <link name="arm_link8">
    <inertial>
      <origin xyz="0.000651231850419722 -0.0491929869131991 0.00972258769184024" rpy="0 0 0"/>
      <mass value="0.025"/>
      <inertia ixx="0.00007371" ixy="-0.00000113" ixz="0.00000021"
               iyy="0.00000781" iyz="-0.00001372" izz="0.0000747"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link8.STL"/>
      </geometry>
      <material name="gripper_black">
        <color rgba="0.08 0.08 0.08 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/piper/link8.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="arm_joint8" type="prismatic">
    <!-- Right finger: slides −Z in link8 local frame (mirrors link7) -->
    <origin xyz="0 0 0.1358" rpy="1.5708 0 -3.1416"/>
    <parent link="arm_gripper_base"/>
    <child  link="arm_link8"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-0.035" upper="0" effort="10" velocity="1"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <!-- ======================================================================
       ROS 2 CONTROL — HARDWARE INTERFACE
       System name covers all 24 joints: 16 dog + 8 arm.
       ====================================================================== -->
  <ros2_control name="m20_with_piper_system" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- ── Dog legs (position) ─────────────────────────────── -->
    <joint name="fl_hipx_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="fl_hipy_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="fl_knee_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="fr_hipx_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="fr_hipy_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="fr_knee_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="hl_hipx_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="hl_hipy_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="hl_knee_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="hr_hipx_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="hr_hipy_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="hr_knee_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>

    <!-- ── Dog wheels (velocity) ───────────────────────────── -->
    <joint name="fl_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="fr_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="hl_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="hr_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>

    <!-- ── Piper arm — 6 revolute joints (position) ─────────── -->
    <joint name="arm_joint1">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="arm_joint2">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="arm_joint3">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="arm_joint4">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="arm_joint5">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="arm_joint6">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>

    <!-- ── Piper gripper — 2 prismatic fingers (position) ───── -->
    <joint name="arm_joint7">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="arm_joint8">
      <command_interface name="position"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ======================================================================
       GAZEBO SENSOR PLUGINS
       ====================================================================== -->

  <!-- Front RGBD camera -->
  <gazebo reference="camera_front_link">
    <sensor name="camera_front" type="rgbd_camera">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <topic>camera_front</topic>
      <gz_frame_id>camera_front_link</gz_frame_id>
      <camera name="camera_front">
        <horizontal_fov>1.0472</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.1</near><far>10.0</far></clip>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.007</stddev></noise>
        <depth_camera><clip><near>0.1</near><far>10.0</far></clip></depth_camera>
        <lens>
          <intrinsics>
            <fx>554.254691</fx><fy>554.254691</fy>
            <cx>320.5</cx><cy>240.5</cy><s>0.0</s>
          </intrinsics>
        </lens>
      </camera>
    </sensor>
  </gazebo>

  <!-- Rear RGBD camera -->
  <gazebo reference="camera_rear_link">
    <sensor name="camera_rear" type="rgbd_camera">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <topic>camera_rear</topic>
      <gz_frame_id>camera_rear_link</gz_frame_id>
      <camera name="camera_rear">
        <horizontal_fov>1.0472</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.1</near><far>10.0</far></clip>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.007</stddev></noise>
        <depth_camera><clip><near>0.1</near><far>10.0</far></clip></depth_camera>
        <lens>
          <intrinsics>
            <fx>554.254691</fx><fy>554.254691</fy>
            <cx>320.5</cx><cy>240.5</cy><s>0.0</s>
          </intrinsics>
        </lens>
      </camera>
    </sensor>
  </gazebo>

  <!-- Front 3-D LiDAR (96-line) -->
  <gazebo reference="lidar_front_link">
    <sensor name="lidar_front" type="gpu_lidar">
      <always_on>1</always_on>
      <update_rate>10</update_rate>
      <topic>lidar_front</topic>
      <gz_frame_id>lidar_front_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>1800</samples><resolution>1</resolution>
            <min_angle>-3.14159265</min_angle><max_angle>3.14159265</max_angle>
          </horizontal>
          <vertical>
            <samples>96</samples><resolution>1</resolution>
            <min_angle>-0.43633231</min_angle><max_angle>0.43633231</max_angle>
          </vertical>
        </scan>
        <range><min>0.1</min><max>50.0</max><resolution>0.01</resolution></range>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
      </lidar>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- Rear 3-D LiDAR (96-line) -->
  <gazebo reference="lidar_rear_link">
    <sensor name="lidar_rear" type="gpu_lidar">
      <always_on>1</always_on>
      <update_rate>10</update_rate>
      <topic>lidar_rear</topic>
      <gz_frame_id>lidar_rear_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>1800</samples><resolution>1</resolution>
            <min_angle>-3.14159265</min_angle><max_angle>3.14159265</max_angle>
          </horizontal>
          <vertical>
            <samples>96</samples><resolution>1</resolution>
            <min_angle>-0.43633231</min_angle><max_angle>0.43633231</max_angle>
          </vertical>
        </scan>
        <range><min>0.1</min><max>50.0</max><resolution>0.01</resolution></range>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
      </lidar>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- IMU -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>200</update_rate>
      <topic>imu/data</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!-- ======================================================================
       GAZEBO SYSTEM PLUGINS
       ====================================================================== -->

  <!-- Sensor rendering (required for RGBD depth output) -->
  <gazebo>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

  <!-- IMU system -->
  <gazebo>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
  </gazebo>

  <!-- Odometry publisher (required by Nav2 / slam_toolbox) -->
  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <odom_publish_frequency>30</odom_publish_frequency>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
    </plugin>
  </gazebo>

  <!-- Joint state publisher -->
  <gazebo>
    <plugin filename="ignition-gazebo-joint-state-publisher-system"
            name="ignition::gazebo::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo>

  <!-- ROS 2 control bridge -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find lynx_quanta)/config/m20_with_piper_controller.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
