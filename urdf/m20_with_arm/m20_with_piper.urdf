<?xml version="1.0" encoding="utf-8"?>
<!--
  ============================================================================
  M20 Lynx  +  AgileX Piper 6-DOF Arm  —  Integrated URDF
  ============================================================================
  Dog base   : DeepRobotics Lynx M20  (16 joints: 12 leg + 4 wheel)
  Arm        : AgileX Piper  (6 revolute + 2 prismatic gripper = 8 joints)
  ============================================================================
  MOUNTING GEOMETRY
    Rail area  : 270 mm (x) × 165 mm (y) on dog back — centred at (0, 0)
    arm_mount_joint origin : xyz="0.0  0.0  0.09"  rpy="0 0 0"
      • z = 0.09 m  ≈  top surface of M20 body (body half-height 0.07 m)
                        + ~20 mm aluminium mounting bracket
    Height budget : 30 cm above mount surface  →  z ≤ 0.39 m from base_link
    Piper in zero-pose: arm folds roughly forward; tallest point ≈ 0.21 m
    above mount → well within budget.

  COORDINATE CONVENTION
    +x  forward   (same as M20 body)
    +y  left
    +z  up
    Arm mounted upright (rpy 0 0 0); joint-1 rotates about global z.

  PREFIX POLICY
    All Piper links  : arm_<original_name>   e.g. arm_base_link, arm_link1 …
    All Piper joints : arm_<original_name>   e.g. arm_joint1 …
    Mesh path        : file://$(find lynx_quanta)/meshes/piper/<file>.STL
  ============================================================================
-->
<robot name="m20_with_piper" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:arg name="ros2_control_yaml" default=""/>

  <!-- ======================================================================
       BASE FOOTPRINT
       ====================================================================== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
       M20 BODY
       ====================================================================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.00355105878308153 0.0016507579200937 -0.00346462146571654" rpy="0 0 0"/>
      <mass value="15.882"/>
      <inertia ixx="0.087919" ixy="0.001396" ixz="0.000111"
               iyy="0.533522" iyz="0.000519" izz="0.563492"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find lynx_quanta)/meshes/m20/base_link.dae"/>
      </geometry>
    </visual>
    <!-- Primary body box -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.75 0.09 0.14"/></geometry>
    </collision>
    <!-- Left rail fillet -->
    <collision>
      <origin xyz="0 0.045 0" rpy="0 1.57079632 0"/>
      <geometry><cylinder length="0.75" radius="0.07"/></geometry>
    </collision>
    <!-- Right rail fillet -->
    <collision>
      <origin xyz="0 -0.045 0" rpy="0 1.57079632 0"/>
      <geometry><cylinder length="0.75" radius="0.07"/></geometry>
    </collision>
  </link>

  <!-- ======================================================================
       FRONT-LEFT LEG
       ====================================================================== -->
